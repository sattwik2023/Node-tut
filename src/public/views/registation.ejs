<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registation Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>

    <div class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="max-w-md w-full bg-white p-8 rounded-lg shadow-lg">
            <h2 class="text-2xl font-bold text-center mb-6">User Registation Page</h2>
            <form onsubmit="handleSubmit(event)" method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Usre Name</label>
                    <input type="text" name="user_name"
                        class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="Enter Your Name" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Email</label>
                    <input type="email" name="email"
                        class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="you@example.com" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Age</label>
                    <input type="text" name="age"
                        class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="Enter Your Age">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Password</label>
                    <input type="password" name="password"
                        class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="••••••••" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Profile Photo</label>
                    <input type="file" name="img"
                        class="mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="Enter Your Profile Photos">
                </div>
                <button type="submit"
                    class="w-full py-2 px-4 bg-indigo-600 text-white rounded-md hover:bg-indigo-700">Sign Up</button>
            </form>
            <p class="mt-4 text-sm text-center text-gray-600">You have an account? <a href="/"
                    class="text-indigo-600 hover:underline">Login Page</a></p>
        </div>
    </div>
    <script>
        async function handleSubmit(e) {
            e.preventDefault()
            // console.log(e.target)
            const formData = new FormData(e.target)
            console.log(formData);
            const data = Object.fromEntries(formData.entries());

            console.log(data);
            const fetchData = await fetch('http://localhost:3000/postregistation',
                {
                    method: "post",
                    // headers: {
                    //     "Content-Type": "application/json"
                    // },
                    body: formData,
                    credentials: "include"

                })
            const apidata = await fetchData.json()
            console.log(apidata.message)
            if (fetchData.ok) {
                alert(apidata.message);
                 window.location.href =  '/'
            } else {
                alert(apidata.message);
            }

        }
    </script>
</body>

</html>